import { LineEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";

export component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 168px;
    min-height: 42px;
    border-radius: 6px;
    background: !root.enabled ? Theme.accent-disabled : touch.pressed ? Theme.accent-primary-pressed : touch.has-hover ? Theme.accent-primary-hover : Theme.accent-primary;

    Text {
        text: root.text;
        color: root.enabled ? Theme.text-on-accent : Theme.text-disabled-on-accent;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

export component SecondaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> active: false;
    callback clicked();

    min-width: 142px;
    min-height: 38px;
    border-radius: 6px;
    border-width: 1px;
    border-color: !root.enabled ? Theme.border-disabled : root.active || touch.has-hover ? Theme.accent-warm : Theme.border-accent-muted;
    background: !root.enabled ? Theme.surface : touch.pressed ? Theme.surface-pressed : root.active ? Theme.surface-accent : touch.has-hover ? Theme.surface-accent : Theme.surface-raised;

    Text {
        text: root.text;
        color: root.enabled ? Theme.text-primary : Theme.text-disabled;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

