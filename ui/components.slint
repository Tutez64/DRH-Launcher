export component MarkdownBlock inherits Rectangle {
    in property <styled-text> text;
    in property <int> kind;
    in property <string> target;
    callback open-target(string);

    property <bool> heading: root.kind >= 1 && root.kind <= 3;
    property <bool> code: root.kind == 6;
    property <bool> quote: root.kind == 7;
    property <bool> rule: root.kind == 8;
    property <bool> target-block: root.kind == 9;
    property <bool> boxed: root.code || root.quote || root.target-block;

    horizontal-stretch: 1;
    height: root.rule ? 13px
        : root.target-block ? markdown-text.preferred-height + target-text.preferred-height + 18px
        : markdown-text.preferred-height + (root.heading ? 10px : root.boxed ? 12px : 6px);
    border-radius: root.boxed ? 5px : 0px;
    border-width: root.quote || root.target-block ? 1px : 0px;
    border-color: root.target-block && touch.has-hover ? Theme.accent-warm : Theme.border-accent-muted;
    background: root.target-block ? touch.pressed ? Theme.surface-pressed : touch.has-hover ? Theme.surface-accent : Theme.surface-raised
        : root.code ? Theme.panel-background
        : root.quote ? Theme.surface-raised
        : transparent;

    if root.rule : Rectangle {
        x: 0px;
        y: 6px;
        width: parent.width;
        height: 1px;
        background: Theme.divider;
    }

    markdown-text := StyledText {
        x: root.boxed ? 10px : 0px;
        y: root.heading ? 5px : root.boxed ? 6px : 3px;
        width: parent.width - self.x - (root.boxed ? 10px : 0px);
        height: self.preferred-height;
        text: root.text;
        default-color: root.heading ? Theme.text-strong : root.code ? Theme.text-secondary : root.quote ? Theme.text-muted : root.target-block ? Theme.text-strong : Theme.text-body;
        default-font-family: root.code ? "Hack" : "";
        default-font-size: root.kind == 1 ? 18px : root.kind == 2 ? 16px : root.kind == 3 ? 14px : 13px;
        link-color: #f07a37;
        link-clicked(link) => {
            root.open-target(link);
        }
    }

    target-text := Text {
        visible: root.target-block && root.target != "";
        x: 10px;
        y: markdown-text.y + markdown-text.preferred-height + 4px;
        width: parent.width - 20px;
        text: root.target;
        color: Theme.text-secondary;
        font-size: 12px;
        wrap: word-wrap;
    }

    touch := TouchArea {
        enabled: root.target-block && root.target != "";
        clicked => {
            root.open-target(root.target);
        }
    }
}

export component MetricBlock inherits Rectangle {
    in property <string> label;
    in property <string> value;

    min-height: 78px;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: Theme.surface;

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        Text {
            text: root.label;
            font-size: 12px;
            font-weight: 700;
            color: Theme.accent-warm;
        }

        Text {
            text: root.value;
            font-size: 15px;
            color: Theme.text-body;
            wrap: word-wrap;
        }
    }
}

export component CompactMetricBlock inherits Rectangle {
    in property <string> label;
    in property <string> value;
    property <length> horizontal-padding: 20px;
    out property <float> measured-min-width-px:
        max(96px, max(label-measurement.preferred-width, value-measurement.preferred-width) + root.horizontal-padding) / 1px;
    callback width-measured(float);

    init => {
        root.width-measured(root.measured-min-width-px);
    }

    changed measured-min-width-px => {
        root.width-measured(root.measured-min-width-px);
    }

    min-width: root.measured-min-width-px * 1px;
    min-height: 52px;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: Theme.panel-background;

    label-measurement := Text {
        text: root.label;
        font-size: 11px;
        font-weight: 700;
        visible: false;
    }

    value-measurement := Text {
        text: root.value;
        font-size: 13px;
        visible: false;
    }

    VerticalLayout {
        padding: 10px;
        spacing: 3px;

        Text {
            text: root.label;
            font-size: 11px;
            font-weight: 700;
            color: Theme.accent-warm;
        }

        Text {
            text: root.value;
            font-size: 13px;
            color: Theme.text-body;
            wrap: word-wrap;
        }
    }
}

export component LinkButton inherits Rectangle {
    in property <string> text;
    in property <int> icon-kind;
    property <length> label-left-padding: 48px;
    property <length> label-right-padding: 16px;
    out property <float> measured-min-width-px:
        max(120px, link-label-measurement.preferred-width + root.label-left-padding + root.label-right-padding) / 1px;
    callback clicked();
    callback width-measured(float);

    init => {
        root.width-measured(root.measured-min-width-px);
    }

    changed measured-min-width-px => {
        root.width-measured(root.measured-min-width-px);
    }

    min-width: root.measured-min-width-px * 1px;
    min-height: 40px;
    border-radius: 6px;
    border-width: 1px;
    border-color: touch.has-hover ? Theme.accent-warm : Theme.border-accent-muted;
    background: touch.pressed ? Theme.surface-pressed : touch.has-hover ? Theme.surface-accent : Theme.surface-raised;

    link-label-measurement := Text {
        text: root.text;
        font-size: 14px;
        font-weight: 600;
        visible: false;
    }

    HorizontalLayout {
        y: (parent.height - self.height) / 2;
        height: 32px;
        width: parent.width;
        padding-left: 14px;
        padding-right: 16px;
        spacing: 9px;
        alignment: center;

        Rectangle {
            width: 32px;
            height: 32px;

            if root.icon-kind == 0 : Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                height: 24px;
                source: @image-url("icons/discord.svg");
                image-fit: contain;
            }

            if root.icon-kind == 1 : Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                height: 24px;
                source: @image-url("icons/github.svg");
                image-fit: contain;
            }
        }

        Text {
            text: root.text;
            color: Theme.text-primary;
            font-size: 14px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

