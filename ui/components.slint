    in property <string> title;
    in property <string> detail;
    in property <string> status;
    in property <bool> active;
    callback clicked();

    height: 72px;
    border-radius: 6px;
    border-width: root.active ? 1px : 0px;
    border-color: Theme.border-accent;
    background: root.active ? Theme.surface-selected : touch.has-hover ? Theme.surface-hover : transparent;

    HorizontalLayout {
        padding-left: 10px;
