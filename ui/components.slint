export component HelpMenuButton inherits Rectangle {
    in property <bool> active;
    callback clicked();

    min-width: 142px;
    min-height: 38px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? Theme.accent-warm : touch.has-hover ? Theme.accent-warm : Theme.border-accent-muted;
    background: root.active ? Theme.surface-accent : touch.pressed ? Theme.surface-pressed : touch.has-hover ? Theme.surface-accent : Theme.surface-raised;

    Text {
        text: "Help";
        width: parent.width;
        color: Theme.text-primary;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Path {
        width: 14px;
        height: 14px;
        x: parent.width - self.width - 18px;
        y: (parent.height - self.height) / 2;
        viewbox-width: 10;
        viewbox-height: 10;
        commands: root.active ? "M 1 7 L 5 3 L 9 7" : "M 1 3 L 5 7 L 9 3";
        stroke: Theme.text-primary;
        stroke-width: 1.8px;
        stroke-line-cap: round;
        stroke-line-join: round;
        fill: transparent;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component HomeDiscordButton inherits Rectangle {
    callback clicked();

    width: 116px;
    height: 36px;
    border-radius: 6px;
    border-width: 1px;
    border-color: touch.has-hover ? Theme.home-community-border-hover : Theme.home-community-border;
    background: touch.pressed ? Theme.home-community-pressed : touch.has-hover ? Theme.home-community-hover : Theme.home-community-background;

    HorizontalLayout {
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: 24px;
        padding-left: 12px;
        padding-right: 13px;
        spacing: 8px;
        alignment: center;

        Rectangle {
            width: 24px;
            height: 24px;

            Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                height: 20px;
                source: @image-url("icons/discord.svg");
                image-fit: contain;
            }
        }

        Text {
            text: "Discord";
            color: Theme.text-primary;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

