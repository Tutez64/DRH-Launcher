export component LaunchOptionToggle inherits Rectangle {
    in property <string> text;
    in property <bool> checked;
    property <length> label-left-padding: 38px;
    property <length> label-right-padding: 12px;
    out property <float> measured-min-width-px:
        max(112px, measurement.preferred-width + root.label-left-padding + root.label-right-padding) / 1px;
    callback toggled(bool);
    callback width-measured(float);

    init => {
        root.width-measured(root.measured-min-width-px);
    }

    changed measured-min-width-px => {
        root.width-measured(root.measured-min-width-px);
    }

    height: 38px;
    min-width: root.measured-min-width-px * 1px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.checked ? Theme.accent-warm : touch.has-hover ? Theme.border-accent-muted : Theme.border-muted;
    background: root.checked ? Theme.surface-checked : touch.has-hover ? Theme.surface-hover : Theme.panel-background;

    measurement := Text {
        text: root.text;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0px;
        wrap: no-wrap;
        overflow: clip;
        opacity: 0;
    }

    Rectangle {
        x: 12px;
        y: (parent.height - self.height) / 2;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        border-width: 2px;
        border-color: root.checked ? Theme.accent-warm : Theme.border-neutral;
        background: root.checked ? Theme.accent-primary : transparent;

        Text {
            visible: root.checked;
            text: "✓";
            color: Theme.text-on-accent;
            font-size: 13px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: root.label-left-padding;
        width: parent.width - root.label-left-padding - root.label-right-padding;
        text: root.text;
        color: root.checked ? Theme.text-primary : Theme.text-muted;
        font-size: 13px;
        font-weight: root.checked ? 700 : 600;
        letter-spacing: 0px;
        wrap: no-wrap;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        clicked => {
            root.toggled(!root.checked);
        }
    }
}

export component InfoHint inherits Rectangle {
    in property <string> text;
    property <bool> hovering: touch.has-hover;
    callback show-tooltip(string, length, length);
    callback hide-tooltip();

    z: 10;
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.border-accent-muted;
    background: touch.has-hover ? Theme.surface-accent : Theme.panel-background;

    Text {
        text: "i";
        color: Theme.text-primary;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    changed hovering => {
        if (root.hovering) {
            root.show-tooltip(root.text, root.absolute-position.x, root.absolute-position.y);
        } else {
            root.hide-tooltip();
        }
    }

    touch := TouchArea {}
}

export component AppLineEdit inherits Rectangle {
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> value;

    horizontal-stretch: 1;
    min-height: input.min-height;

    input := LineEdit {
        width: parent.width;
        enabled: root.enabled;
        placeholder-text: root.placeholder;
        text <=> root.value;
    }

    Rectangle {
        visible: input.has-focus;
        width: parent.width;
        height: input.height;
        border-radius: 4px;
        border-width: 2px;
        border-color: Theme.focus;
    }
}

export component NumericTextField inherits Rectangle {
    in-out property <string> value;

    width: 48px;
    height: 34px;
    border-radius: 6px;
    border-width: input.has-focus ? 2px : 1px;
    border-color: input.has-focus ? Theme.focus : Theme.border-accent-muted;
    background: Theme.surface-raised;

    input := TextInput {
        x: 6px;
        y: 0px;
        width: parent.width - 12px;
        height: parent.height;
        text <=> root.value;
        single-line: true;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: Theme.text-primary;
        font-size: 14px;
        font-weight: 700;
    }
}

export component LaunchTextField inherits Rectangle {
    in property <string> label;
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> value;

    horizontal-stretch: 1;
    min-width: 260px;
    min-height: 64px;

    VerticalLayout {
        spacing: 8px;

        SmallLabel {
            label: root.label;
        }

        AppLineEdit {
            enabled: root.enabled;
            placeholder: root.placeholder;
            value <=> root.value;
        }
    }
}

