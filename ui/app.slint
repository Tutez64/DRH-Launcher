}

component GameSessionButton inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <bool> active;
    callback clicked();

    height: 58px;
    border-radius: 6px;
    border-width: root.active ? 1px : 0px;
    border-color: Theme.border-accent;
    background: root.active ? Theme.surface-selected : touch.has-hover ? Theme.surface-hover : transparent;

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 7px;
        padding-bottom: 7px;
        spacing: 3px;

        Text {
            text: root.title;
            color: Theme.text-primary;
            font-size: 12px;
            font-weight: root.active ? 700 : 600;
            overflow: elide;
        }

        Text {
            text: root.detail;
            color: Theme.text-support;
            font-size: 11px;
            overflow: elide;
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component LogViewer inherits Rectangle {
    in property <string> title;
    in property <[LogLineView]> lines;
    in property <bool> scroll-to-end;
    callback wrap-columns-measured(int);
    property <int> scroll-ticks: 0;
    property <int> line-count: root.lines.length;
    property <int> reported-wrap-columns: 0;

    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border-muted;
    background: Theme.panel-background;

    changed line-count => {
        root.scroll-ticks = 0;
        log-list.viewport-y = root.scroll-to-end ? -100000px : 0px;
    }

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        Text {
            text: root.title;
            color: Theme.text-secondary;
            font-size: 12px;
            font-weight: 700;
        }

        character-measurement := Text {
            text: "MMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMMM";
            font-family: "Hack";
            font-size: 13px;
            visible: false;
        }

        log-list := ListView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            opacity: root.reported-wrap-columns > 0 ? 1 : 0;

            for line in root.lines: Rectangle {
                height: 20px;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: line.text;
                    font-family: "Hack";
                    font-size: 13px;
                    color: line.color;
                    wrap: no-wrap;
                    overflow: clip;
                    vertical-alignment: center;
                }
            }
        }

        scroll-log-to-end := Timer {
            interval: 1ms;
            running: root.scroll-to-end && root.scroll-ticks < 2;

            triggered => {
                log-list.viewport-y = -100000px;
                root.scroll-ticks += 1;
            }
        }

        report-wrap-columns := Timer {
            interval: 100ms;
            running: true;

            triggered => {
                let character-width-px = character-measurement.preferred-width / 64px;
                if (character-width-px > 0) {
                    let columns = max(
                        20,
                        floor(log-list.visible-width / 1px / character-width-px),
                    );
                    if (columns != root.reported-wrap-columns) {
                        root.reported-wrap-columns = columns;
                        root.wrap-columns-measured(root.reported-wrap-columns);
                    }
                }
            }
        }
    }
}

component MetricBlock inherits Rectangle {
    in property <string> label;
    in property <string> value;

    min-height: 78px;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: Theme.surface;

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        Text {
            text: root.label;
            font-size: 12px;
            font-weight: 700;
            color: Theme.accent-warm;
        }

        Text {
            text: root.value;
            font-size: 15px;
            color: Theme.text-body;
            wrap: word-wrap;
        }
    }
}

component CompactMetricBlock inherits Rectangle {
    in property <string> label;
    in property <string> value;
    property <length> horizontal-padding: 20px;
    out property <float> measured-min-width-px:
        max(96px, max(label-measurement.preferred-width, value-measurement.preferred-width) + root.horizontal-padding) / 1px;
    callback width-measured(float);

    init => {
        root.width-measured(root.measured-min-width-px);
    }

    changed measured-min-width-px => {
        root.width-measured(root.measured-min-width-px);
    }

    min-width: root.measured-min-width-px * 1px;
    min-height: 52px;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: Theme.panel-background;

    label-measurement := Text {
        text: root.label;
        font-size: 11px;
        font-weight: 700;
        visible: false;
    }

    value-measurement := Text {
        text: root.value;
        font-size: 13px;
        visible: false;
    }

    VerticalLayout {
        padding: 10px;
        spacing: 3px;

        Text {
            text: root.label;
            font-size: 11px;
            font-weight: 700;
            color: Theme.accent-warm;
        }

        Text {
            text: root.value;
            font-size: 13px;
            color: Theme.text-body;
            wrap: word-wrap;
        }
    }
}

component LinkButton inherits Rectangle {
    in property <string> text;
    in property <int> icon-kind;
    property <length> label-left-padding: 48px;
    property <length> label-right-padding: 16px;
    out property <float> measured-min-width-px:
        max(120px, link-label-measurement.preferred-width + root.label-left-padding + root.label-right-padding) / 1px;
    callback clicked();
    callback width-measured(float);

    init => {
        root.width-measured(root.measured-min-width-px);
    }

    changed measured-min-width-px => {
        root.width-measured(root.measured-min-width-px);
    }

    min-width: root.measured-min-width-px * 1px;
    min-height: 40px;
    border-radius: 6px;
    border-width: 1px;
    border-color: touch.has-hover ? Theme.accent-warm : Theme.border-accent-muted;
    background: touch.pressed ? Theme.surface-pressed : touch.has-hover ? Theme.surface-accent : Theme.surface-raised;

    link-label-measurement := Text {
        text: root.text;
        font-size: 14px;
        font-weight: 600;
        visible: false;
    }

    HorizontalLayout {
        y: (parent.height - self.height) / 2;
        height: 32px;
        width: parent.width;
        padding-left: 14px;
        padding-right: 16px;
        spacing: 9px;
        alignment: center;

        Rectangle {
            width: 32px;
            height: 32px;

            if root.icon-kind == 0 : Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                height: 24px;
                source: @image-url("icons/discord.svg");
                image-fit: contain;
            }

            if root.icon-kind == 1 : Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                height: 24px;
                source: @image-url("icons/github.svg");
                image-fit: contain;
            }
        }

        Text {
            text: root.text;
            color: Theme.text-primary;
            font-size: 14px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

