import { LineEdit, ListView, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import "../assets/fonts/Hack-Regular.ttf";

export struct LaunchOptionView {
    name: string,
    flag: string,
    checked: bool,
}

export struct LogLineView {
    text: string,
    color: brush,
}

export struct GameSessionView {
    title: string,
    detail: string,
}

component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 168px;
    min-height: 42px;
    border-radius: 6px;
    background: !root.enabled ? Theme.accent-disabled : touch.pressed ? Theme.accent-primary-pressed : touch.has-hover ? Theme.accent-primary-hover : Theme.accent-primary;

    Text {
        text: root.text;
        color: root.enabled ? Theme.text-on-accent : Theme.text-disabled-on-accent;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component SecondaryButton inherits Rectangle {
