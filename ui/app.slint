component HelpMenuButton inherits Rectangle {
    in property <bool> active;
    callback clicked();

    min-width: 142px;
    min-height: 38px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? Theme.accent-warm : touch.has-hover ? Theme.accent-warm : Theme.border-accent-muted;
    background: root.active ? Theme.surface-accent : touch.pressed ? Theme.surface-pressed : touch.has-hover ? Theme.surface-accent : Theme.surface-raised;

    Text {
        text: "Help";
        width: parent.width;
        color: Theme.text-primary;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Path {
        width: 14px;
        height: 14px;
        x: parent.width - self.width - 18px;
        y: (parent.height - self.height) / 2;
        viewbox-width: 10;
        viewbox-height: 10;
        commands: root.active ? "M 1 7 L 5 3 L 9 7" : "M 1 3 L 5 7 L 9 3";
        stroke: Theme.text-primary;
        stroke-width: 1.8px;
        stroke-line-cap: round;
        stroke-line-join: round;
        fill: transparent;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

