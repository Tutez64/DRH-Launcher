import { Button } from "std-widgets.slint";

component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 168px;
    min-height: 42px;
    border-radius: 6px;
    background: !root.enabled ? #5b2723 : touch.pressed ? #9f241c : touch.has-hover ? #e1502f : #c73325;

    Text {
        text: root.text;
        color: root.enabled ? #fff7ed : #a9948d;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component SecondaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 142px;
    min-height: 42px;
    border-radius: 6px;
    border-width: 1px;
    border-color: !root.enabled ? #3f302d : touch.has-hover ? #f07a37 : #6d3327;
    background: !root.enabled ? #18171a : touch.pressed ? #3a1c18 : touch.has-hover ? #2b1816 : #20171a;

    Text {
        text: root.text;
        color: root.enabled ? #f3d8c4 : #776b66;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

export component AppWindow inherits Window {
    in property <string> install-status;
    in property <string> version-status;
    in property <string> install-action-text;
    in property <bool> install-action-enabled: true;
    in property <string> update-check-text: "Check for updates";
    in property <bool> update-check-enabled: true;
    in property <string> activity-message;

    callback install-or-play();
    callback check-updates();
    callback open-settings();

    title: "DRH Launcher";
    preferred-width: 920px;
    preferred-height: 560px;
    min-width: 760px;
    min-height: 460px;
    background: #111116;

    VerticalLayout {
        padding: 28px;
        spacing: 22px;

        HorizontalLayout {
            spacing: 16px;

            VerticalLayout {
                spacing: 5px;

                Text {
                    text: "DRH Launcher";
                    font-size: 30px;
                    font-weight: 700;
                    color: #fff2df;
                }

                Text {
                    text: "Updates, launch options and future mod management for Dungeon Rampage Haxe.";
                    font-size: 14px;
                    color: #a99b91;
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            SecondaryButton {
                text: "Settings";
                clicked => {
                    root.open-settings();
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #3b2925;
        }

        VerticalLayout {
            spacing: 14px;

            Text {
                text: root.install-status;
                font-size: 22px;
                font-weight: 600;
                color: #ffe3c0;
            }

            Text {
                text: root.version-status;
                font-size: 15px;
                color: #b9aea6;
            }

            HorizontalLayout {
                spacing: 12px;

                PrimaryButton {
                    text: root.install-action-text;
                    enabled: root.install-action-enabled;
                    clicked => {
                        root.install-or-play();
                    }
                }

                SecondaryButton {
                    text: root.update-check-text;
                    enabled: root.update-check-enabled;
                    clicked => {
                        root.check-updates();
                    }
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
        }

        Rectangle {
            border-color: #563025;
            border-width: 1px;
            border-radius: 6px;
            background: #18151a;
            min-height: 82px;

            VerticalLayout {
                padding: 14px;
                spacing: 6px;

                Text {
                    text: "Status";
                    font-size: 13px;
                    font-weight: 700;
                    color: #f07a37;
                }

                Text {
                    text: root.activity-message;
                    font-size: 14px;
                    color: #dbc8bd;
                }
            }
        }
    }
}
