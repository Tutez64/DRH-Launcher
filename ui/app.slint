import { LineEdit, ScrollView } from "std-widgets.slint";

export struct LaunchOptionView {
    name: string,
    flag: string,
    checked: bool,
}

export struct LogLineView {
    text: string,
    color: brush,
}

component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 168px;
    min-height: 42px;
    border-radius: 6px;
    background: !root.enabled ? #5b2723 : touch.pressed ? #9f241c : touch.has-hover ? #e1502f : #c73325;

    Text {
        text: root.text;
        color: root.enabled ? #fff7ed : #a9948d;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component SecondaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 142px;
    min-height: 38px;
    border-radius: 6px;
    border-width: 1px;
    border-color: !root.enabled ? #3f302d : touch.has-hover ? #f07a37 : #6d3327;
    background: !root.enabled ? #18171a : touch.pressed ? #3a1c18 : touch.has-hover ? #2b1816 : #20171a;

    Text {
        text: root.text;
        color: root.enabled ? #f3d8c4 : #776b66;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component NavButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    height: 42px;
    border-radius: 6px;
    background: root.active ? #3a1f1b : touch.has-hover ? #211b1e : transparent;
    border-width: root.active ? 1px : 0px;
    border-color: #743325;

    Text {
        text: root.text;
        color: root.active ? #fff1dd : #cbb8ab;
        font-size: 14px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: left;
        vertical-alignment: center;
        x: 14px;
        width: parent.width - 28px;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    min-width: 108px;
    height: 36px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? #743325 : #342724;
    background: root.active ? #3a1f1b : touch.has-hover ? #211b1e : #151419;

    Text {
        text: root.text;
        color: root.active ? #fff1dd : #cbb8ab;
        font-size: 13px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component MetricBlock inherits Rectangle {
    in property <string> label;
    in property <string> value;

    min-height: 78px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #3c2a26;
    background: #17151a;

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        Text {
            text: root.label;
            font-size: 12px;
            font-weight: 700;
            color: #f07a37;
        }

        Text {
            text: root.value;
            font-size: 15px;
            color: #ead8ca;
            wrap: word-wrap;
        }
    }
}

component SectionTitle inherits Text {
    in property <string> title;

    text: root.title;
    font-size: 18px;
    font-weight: 700;
    color: #fff0dc;
}

component SmallLabel inherits Text {
    in property <string> label;

    text: root.label;
    font-size: 12px;
    font-weight: 700;
    color: #c48a66;
}

component SegmentedButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    min-width: 132px;
    height: 34px;
    border-width: 1px;
    border-color: root.active ? #f07a37 : #342724;
    background: root.active ? #3a1f1b : touch.has-hover ? #211b1e : #151419;

    Text {
        text: root.text;
        color: root.active ? #fff1dd : #cbb8ab;
        font-size: 13px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component LaunchOptionToggle inherits Rectangle {
    in property <string> text;
    in property <bool> checked;
    property <length> label-left-padding: 38px;
    property <length> label-right-padding: 12px;
    out property <float> measured-min-width-px:
        max(112px, measurement.preferred-width + root.label-left-padding + root.label-right-padding) / 1px;
    callback toggled(bool);
    callback width-measured(float);

    init => {
        root.width-measured(root.measured-min-width-px);
    }

    changed measured-min-width-px => {
        root.width-measured(root.measured-min-width-px);
    }

    height: 38px;
    min-width: root.measured-min-width-px * 1px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.checked ? #f07a37 : touch.has-hover ? #6d3327 : #342724;
    background: root.checked ? #2a1c18 : touch.has-hover ? #211b1e : #151419;

    measurement := Text {
        text: root.text;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0px;
        wrap: no-wrap;
        overflow: clip;
        opacity: 0;
    }

    Rectangle {
        x: 12px;
        y: (parent.height - self.height) / 2;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        border-width: 2px;
        border-color: root.checked ? #f07a37 : #8a7568;
        background: root.checked ? #c73325 : transparent;

        Text {
            visible: root.checked;
            text: "✓";
            color: #fff7ed;
            font-size: 13px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: root.label-left-padding;
        width: parent.width - root.label-left-padding - root.label-right-padding;
        text: root.text;
        color: root.checked ? #fff1dd : #cbb8ab;
        font-size: 13px;
        font-weight: root.checked ? 700 : 600;
        letter-spacing: 0px;
        wrap: no-wrap;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        clicked => {
            root.toggled(!root.checked);
        }
    }
}

component InfoHint inherits Rectangle {
    in property <string> text;
    property <bool> hovering: touch.has-hover;
    callback show-tooltip(string, length, length);
    callback hide-tooltip();

    z: 10;
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border-width: 1px;
    border-color: #6d3327;
    background: touch.has-hover ? #2b1816 : #151419;

    Text {
        text: "i";
        color: #f3d8c4;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    changed hovering => {
        if (root.hovering) {
            root.show-tooltip(root.text, root.absolute-position.x, root.absolute-position.y);
        } else {
            root.hide-tooltip();
        }
    }

    touch := TouchArea {}
}

component AppLineEdit inherits Rectangle {
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> value;

    horizontal-stretch: 1;
    min-height: input.min-height;

    input := LineEdit {
        width: parent.width;
        enabled: root.enabled;
        placeholder-text: root.placeholder;
        text <=> root.value;
    }

    Rectangle {
        visible: input.has-focus;
        width: parent.width;
        height: input.height;
        border-radius: 4px;
        border-width: 2px;
        border-color: #e1502f;
    }
}

component LaunchTextField inherits Rectangle {
    in property <string> label;
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> value;

    horizontal-stretch: 1;
    min-width: 260px;
    min-height: 64px;

    VerticalLayout {
        spacing: 8px;

        SmallLabel {
            label: root.label;
        }

        AppLineEdit {
            enabled: root.enabled;
            placeholder: root.placeholder;
            value <=> root.value;
        }
    }
}

export component AppWindow inherits Window {
    in property <string> install-status;
    in property <string> version-status;
    in property <string> install-action-text;
    in property <bool> install-action-enabled: true;
    in property <string> update-check-text: "Check for updates";
    in property <bool> update-check-enabled: true;
    in property <string> home-support-text;
    in property <string> status-detail;
    in property <[LogLineView]> log-lines;
    in property <string> launcher-version;
    in property <string> release-source-label;
    in property <string> config-path;
    in-out property <string> pre-launch-command;
    in-out property <int> launch-arguments-mode: 1;
    in-out property <string> custom-game-args;
    in-out property <string> saved-pre-launch-command;
    in-out property <int> saved-launch-arguments-mode: 1;
    in-out property <string> saved-custom-game-args;
    in-out property <string> launch-options-save-text: "Save";
    in property <[LaunchOptionView]> launch-options;
    in property <float> launch-option-min-width-px: 210;
    in-out property <string> launch-options-state;
    in-out property <string> saved-launch-options-state;
    property <bool> launch-options-dirty: root.pre-launch-command != root.saved-pre-launch-command
        || root.launch-arguments-mode != root.saved-launch-arguments-mode
        || root.launch-options-state != root.saved-launch-options-state
        || root.custom-game-args != root.saved-custom-game-args;
    in property <bool> open-install-folder-enabled: false;
    in property <bool> open-logs-folder-enabled: false;
    in-out property <int> active-page: 0;
    in-out property <int> settings-page: 0;
    property <int> logs-scroll-ticks: 0;
    property <int> logs-restore-ticks: 0;
    in-out property <length> logs-viewport-y: 0px;
    property <bool> info-tooltip-visible: false;
    property <string> info-tooltip-text;
    property <length> info-tooltip-anchor-x: 0px;
    property <length> info-tooltip-anchor-y: 0px;

    callback install-or-play();
    callback check-updates();
    callback open-settings();
    callback open-install-folder();
    callback open-logs-folder();
    callback refresh-logs();
    callback save-launch-options();
    callback select-launch-arguments-mode(int);
    callback toggle-launch-option(int, bool);
    callback launch-option-width-measured(float);
    callback cancel-launch-options();

    title: "DRH Launcher";
    preferred-width: 1280px;
    preferred-height: 720px;
    min-width: 820px;
    min-height: 520px;
    background: #0f1014;

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: 188px;
            background: #121116;

            VerticalLayout {
                padding: 18px;
                spacing: 10px;

                Text {
                    text: "Dungeon Rampage Haxe";
                    color: #ffe6c5;
                    font-size: 14px;
                    font-weight: 800;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 12px;
                }

                NavButton {
                    text: "Home";
                    active: root.active-page == 0;
                    clicked => {
                        root.active-page = 0;
                    }
                }

                NavButton {
                    text: "Options";
                    active: root.active-page == 1;
                    clicked => {
                        root.active-page = 1;
                    }
                }

                NavButton {
                    text: "Mods";
                    active: root.active-page == 2;
                    clicked => {
                        root.active-page = 2;
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                NavButton {
                    text: "Settings";
                    active: root.active-page == 3;
                    clicked => {
                        root.logs-restore-ticks = 0;
                        root.active-page = 3;
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: #30231f;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: #0f1014;

            VerticalLayout {
                padding: 26px;
                spacing: 18px;

                if root.active-page == 0 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        Rectangle {
                            vertical-stretch: 1;
                        }

                        HorizontalLayout {
                            alignment: center;

                            PrimaryButton {
                                text: root.install-action-text;
                                enabled: root.install-action-enabled;
                                clicked => {
                                    root.install-or-play();
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: root.home-support-text;
                                font-size: 13px;
                                color: #a99b91;
                                horizontal-alignment: center;
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: center;

                            SecondaryButton {
                                text: root.update-check-text;
                                enabled: root.update-check-enabled;
                                clicked => {
                                    root.check-updates();
                                }
                            }

                            SecondaryButton {
                                text: "Options";
                                clicked => {
                                    root.active-page = 1;
                                }
                            }

                            SecondaryButton {
                                text: "Repair";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Logs";
                                clicked => {
                                    root.logs-restore-ticks = 0;
                                    root.active-page = 3;
                                    root.settings-page = 1;
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 1 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        options-page-scroll := ScrollView {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            viewport-width: self.width;
                            viewport-height: options-page-content.preferred-height;

                            options-page-content := VerticalLayout {
                                width: options-page-scroll.width;
                                spacing: 12px;

                                LaunchTextField {
                                    label: "Pre-launch command";
                                    placeholder: "mangohud, gamescope, prime-run...";
                                    value <=> root.pre-launch-command;
                                }

                                VerticalLayout {
                                    spacing: 8px;

                                    HorizontalLayout {
                                        z: 10;
                                        spacing: 8px;
                                        alignment: start;

                                        SmallLabel {
                                            label: "Arguments";
                                        }

                                        InfoHint {
                                            text: "These are original Dungeon Rampage launch options.\nGame defaults uses the game's own defaults.\nDRHL recommended is the launcher default.\nCustom lets you adjust known options manually.";
                                            show-tooltip(text, x, y) => {
                                                root.info-tooltip-text = text;
                                                root.info-tooltip-anchor-x = x;
                                                root.info-tooltip-anchor-y = y;
                                                root.info-tooltip-visible = true;
                                            }
                                            hide-tooltip => {
                                                root.info-tooltip-visible = false;
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 0px;

                                        SegmentedButton {
                                            text: "Game defaults";
                                            active: root.launch-arguments-mode == 0;
                                            clicked => {
                                                root.select-launch-arguments-mode(0);
                                            }
                                        }

                                        SegmentedButton {
                                            text: "DRHL recommended";
                                            active: root.launch-arguments-mode == 1;
                                            clicked => {
                                                root.select-launch-arguments-mode(1);
                                            }
                                        }

                                        SegmentedButton {
                                            text: "Custom";
                                            active: root.launch-arguments-mode == 2;
                                            clicked => {
                                                root.select-launch-arguments-mode(2);
                                            }
                                        }
                                    }

                                    if root.launch-options.length > 0 : option-area := Rectangle {
                                        horizontal-stretch: 1;
                                        height: option-grid.preferred-height;

                                        option-grid := GridLayout {
                                            width: parent.width;
                                            property <length> available-width: option-area.width;
                                            property <int> columns:
                                                option-grid.available-width >= root.launch-option-min-width-px * 4px + 24px ? 4
                                                : option-grid.available-width >= root.launch-option-min-width-px * 3px + 16px ? 3
                                                : option-grid.available-width >= root.launch-option-min-width-px * 2px + 8px ? 2
                                                : 1;
                                            spacing: 8px;

                                            for option[index] in root.launch-options: LaunchOptionToggle {
                                                min-width: root.launch-option-min-width-px * 1px;
                                                row: index / option-grid.columns;
                                                col: Math.mod(index, option-grid.columns);
                                                text: option.name;
                                                checked: option.checked;
                                                toggled(checked) => {
                                                    root.toggle-launch-option(index, checked);
                                                }
                                                width-measured(width) => {
                                                    root.launch-option-width-measured(width);
                                                }
                                            }
                                        }
                                    }

                                    if root.launch-options.length == 0 : Text {
                                        text: "No known launch options loaded from the release manifest.";
                                        color: #a99b91;
                                        font-size: 13px;
                                    }

                                    SmallLabel {
                                        label: "Extra arguments";
                                    }

                                    AppLineEdit {
                                        placeholder: "Extra arguments";
                                        value <=> root.custom-game-args;
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: end;

                            SecondaryButton {
                                text: "Cancel";
                                enabled: root.launch-options-dirty;
                                clicked => {
                                    root.cancel-launch-options();
                                }
                            }

                            PrimaryButton {
                                text: root.launch-options-dirty ? "Save" : root.launch-options-save-text;
                                enabled: root.launch-options-dirty;
                                clicked => {
                                    root.save-launch-options();
                                }
                            }
                        }

                        reset-save-button := Timer {
                            interval: 2s;
                            running: root.launch-options-save-text != "Save";
                            triggered => {
                                root.launch-options-save-text = "Save";
                            }
                        }
                    }
                }

                if root.active-page == 2 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Mods";
                        }

                        MetricBlock {
                            label: "Mod management";
                            value: "Modding isn't supported yet.";
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            SecondaryButton {
                                text: "Import";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Open folder";
                                enabled: false;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 3 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Settings";
                        }

                        HorizontalLayout {
                            spacing: 8px;

                            TabButton {
                                text: "General";
                                active: root.settings-page == 0;
                                clicked => {
                                    root.settings-page = 0;
                                }
                            }

                            TabButton {
                                text: "Logs";
                                active: root.settings-page == 1;
                                clicked => {
                                    root.logs-restore-ticks = 0;
                                    root.settings-page = 1;
                                }
                            }

                            TabButton {
                                text: "About";
                                active: root.settings-page == 2;
                                clicked => {
                                    root.settings-page = 2;
                                }
                            }
                        }

                        if root.settings-page == 0 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            MetricBlock {
                                label: "Install folder";
                                value: "Current launcher configuration.";
                            }

                            MetricBlock {
                                label: "Config file";
                                value: root.config-path;
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                SecondaryButton {
                                    text: "Open install folder";
                                    enabled: root.open-install-folder-enabled;
                                    clicked => {
                                        root.open-install-folder();
                                    }
                                }

                                SecondaryButton {
                                    text: "Open config";
                                    clicked => {
                                        root.open-settings();
                                    }
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }
                        }

                        if root.settings-page == 1 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            Rectangle {
                                vertical-stretch: 1;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: #342724;
                                background: #151419;

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;

                                    SmallLabel {
                                        label: "Recent launcher log";
                                    }

                                    log-scroll := ScrollView {
                                        visible: root.logs-scroll-ticks > 0 && root.logs-restore-ticks > 0;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;
                                        viewport-width: self.width;
                                        viewport-height: log-lines-layout.preferred-height;

                                        changed viewport-y => {
                                            if (root.logs-scroll-ticks >= 2 && root.logs-restore-ticks > 0) {
                                                root.logs-viewport-y = self.viewport-y;
                                            }
                                        }

                                        log-lines-layout := VerticalLayout {
                                            width: parent.viewport-width;
                                            min-width: 0px;
                                            spacing: 2px;

                                            for line in root.log-lines: Text {
                                                text: line.text;
                                                width: parent.width;
                                                font-size: 13px;
                                                color: line.color;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }

                                    scroll-logs-to-end := Timer {
                                        interval: 1ms;
                                        running: root.active-page == 3 && root.settings-page == 1 && root.logs-scroll-ticks < 2;

                                        triggered => {
                                            log-scroll.viewport-y = -100000px;
                                            root.logs-scroll-ticks += 1;
                                            if (root.logs-scroll-ticks >= 2) {
                                                root.logs-viewport-y = Math.min(0px, log-scroll.height - log-lines-layout.preferred-height);
                                                root.logs-restore-ticks = 1;
                                            }
                                        }
                                    }

                                    restore-logs-position := Timer {
                                        interval: 1ms;
                                        running: root.active-page == 3 && root.settings-page == 1 && root.logs-scroll-ticks >= 2 && root.logs-restore-ticks < 1;

                                        triggered => {
                                            log-scroll.viewport-y = root.logs-viewport-y;
                                            root.logs-restore-ticks += 1;
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                SecondaryButton {
                                    text: "Open logs folder";
                                    enabled: root.open-logs-folder-enabled;
                                    clicked => {
                                        root.open-logs-folder();
                                    }
                                }

                                SecondaryButton {
                                    text: "Refresh";
                                    enabled: root.open-logs-folder-enabled;
                                    clicked => {
                                        root.logs-scroll-ticks = 0;
                                        root.logs-restore-ticks = 0;
                                        root.logs-viewport-y = 0px;
                                        root.refresh-logs();
                                    }
                                }
                            }
                        }

                        if root.settings-page == 2 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            MetricBlock {
                                label: "DRH Launcher";
                                value: root.launcher-version;
                            }

                            MetricBlock {
                                label: "Release source";
                                value: root.release-source-label;
                            }

                            MetricBlock {
                                label: "License";
                                value: "GPL-3.0-or-later";
                            }

                            SecondaryButton {
                                text: "GitHub";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Discord";
                                enabled: false;
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        z: 1000;
        visible: root.info-tooltip-visible;
        width: min(390px, root.width - 16px);
        height: info-tooltip-text.preferred-height + 16px;
        x: min(max(root.info-tooltip-anchor-x - 74px, 8px), root.width - self.width - 8px);
        y: max(root.info-tooltip-anchor-y - self.height - 14px, 8px);
        border-radius: 6px;
        border-width: 1px;
        border-color: #6d3327;
        background: #20171a;

        info-tooltip-text := Text {
            x: 10px;
            y: 8px;
            width: parent.width - 20px;
            text: root.info-tooltip-text;
            color: #ead8ca;
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}
