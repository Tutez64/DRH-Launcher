    Text {
        text: root.text;
        color: root.active ? Theme.text-primary : Theme.text-muted;
        font-size: 14px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: left;
        vertical-alignment: center;
        x: 14px;
        width: parent.width - 28px;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

