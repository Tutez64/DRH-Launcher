import { LineEdit, ScrollView } from "std-widgets.slint";

component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 168px;
    min-height: 42px;
    border-radius: 6px;
    background: !root.enabled ? #5b2723 : touch.pressed ? #9f241c : touch.has-hover ? #e1502f : #c73325;

    Text {
        text: root.text;
        color: root.enabled ? #fff7ed : #a9948d;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component SecondaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 142px;
    min-height: 38px;
    border-radius: 6px;
    border-width: 1px;
    border-color: !root.enabled ? #3f302d : touch.has-hover ? #f07a37 : #6d3327;
    background: !root.enabled ? #18171a : touch.pressed ? #3a1c18 : touch.has-hover ? #2b1816 : #20171a;

    Text {
        text: root.text;
        color: root.enabled ? #f3d8c4 : #776b66;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component NavButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    height: 42px;
    border-radius: 6px;
    background: root.active ? #3a1f1b : touch.has-hover ? #211b1e : transparent;
    border-width: root.active ? 1px : 0px;
    border-color: #743325;

    Text {
        text: root.text;
        color: root.active ? #fff1dd : #cbb8ab;
        font-size: 14px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: left;
        vertical-alignment: center;
        x: 14px;
        width: parent.width - 28px;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    min-width: 108px;
    height: 36px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? #743325 : #342724;
    background: root.active ? #3a1f1b : touch.has-hover ? #211b1e : #151419;

    Text {
        text: root.text;
        color: root.active ? #fff1dd : #cbb8ab;
        font-size: 13px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component MetricBlock inherits Rectangle {
    in property <string> label;
    in property <string> value;

    min-height: 78px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #3c2a26;
    background: #17151a;

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        Text {
            text: root.label;
            font-size: 12px;
            font-weight: 700;
            color: #f07a37;
        }

        Text {
            text: root.value;
            font-size: 15px;
            color: #ead8ca;
            wrap: word-wrap;
        }
    }
}

component SectionTitle inherits Text {
    in property <string> title;

    text: root.title;
    font-size: 18px;
    font-weight: 700;
    color: #fff0dc;
}

component SmallLabel inherits Text {
    in property <string> label;

    text: root.label;
    font-size: 12px;
    font-weight: 700;
    color: #c48a66;
}

component SegmentedButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    min-width: 132px;
    height: 34px;
    border-width: 1px;
    border-color: root.active ? #f07a37 : #342724;
    background: root.active ? #3a1f1b : touch.has-hover ? #211b1e : #151419;

    Text {
        text: root.text;
        color: root.active ? #fff1dd : #cbb8ab;
        font-size: 13px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component InfoHint inherits Rectangle {
    in property <string> text;

    z: 10;
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border-width: 1px;
    border-color: #6d3327;
    background: touch.has-hover ? #2b1816 : #151419;

    Text {
        text: "i";
        color: #f3d8c4;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Rectangle {
        z: 20;
        x: -74px;
        y: -1 * self.height - 14px;
        width: 390px;
        height: hint-text.preferred-height + 16px;
        border-radius: 6px;
        border-width: 1px;
        border-color: #6d3327;
        background: #20171a;
        visible: touch.has-hover;

        hint-text := Text {
            x: 10px;
            y: 8px;
            width: parent.width - 20px;
            text: root.text;
            color: #ead8ca;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    touch := TouchArea {}
}

component LaunchTextField inherits Rectangle {
    in property <string> label;
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> value;

    horizontal-stretch: 1;
    min-width: 260px;
    min-height: 64px;

    VerticalLayout {
        spacing: 8px;

        SmallLabel {
            label: root.label;
        }

        LineEdit {
            horizontal-stretch: 1;
            enabled: root.enabled;
            placeholder-text: root.placeholder;
            text <=> root.value;
        }
    }
}

export component AppWindow inherits Window {
    in property <string> install-status;
    in property <string> version-status;
    in property <string> install-action-text;
    in property <bool> install-action-enabled: true;
    in property <string> update-check-text: "Check for updates";
    in property <bool> update-check-enabled: true;
    in property <string> home-support-text;
    in property <string> status-detail;
    in property <string> logs-content;
    in property <string> launcher-version;
    in property <string> release-source-label;
    in property <string> config-path;
    in-out property <string> pre-launch-command;
    in-out property <int> launch-arguments-mode: 1;
    in-out property <string> custom-game-args;
    in-out property <string> saved-pre-launch-command;
    in-out property <int> saved-launch-arguments-mode: 1;
    in-out property <string> saved-custom-game-args;
    in-out property <string> launch-options-save-text: "Save";
    property <bool> launch-options-dirty: root.pre-launch-command != root.saved-pre-launch-command
        || root.launch-arguments-mode != root.saved-launch-arguments-mode
        || root.custom-game-args != root.saved-custom-game-args;
    in property <bool> open-install-folder-enabled: false;
    in property <bool> open-logs-folder-enabled: false;
    in-out property <int> active-page: 0;
    in-out property <int> settings-page: 0;
    property <int> logs-scroll-ticks: 0;

    callback install-or-play();
    callback check-updates();
    callback open-settings();
    callback open-install-folder();
    callback open-logs-folder();
    callback refresh-logs();
    callback save-launch-options();

    title: "DRH Launcher";
    preferred-width: 980px;
    preferred-height: 620px;
    min-width: 820px;
    min-height: 520px;
    background: #0f1014;

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: 188px;
            background: #121116;

            VerticalLayout {
                padding: 18px;
                spacing: 10px;

                Text {
                    text: "Dungeon Rampage Haxe";
                    color: #ffe6c5;
                    font-size: 14px;
                    font-weight: 800;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 12px;
                }

                NavButton {
                    text: "Home";
                    active: root.active-page == 0;
                    clicked => {
                        root.active-page = 0;
                    }
                }

                NavButton {
                    text: "Options";
                    active: root.active-page == 1;
                    clicked => {
                        root.active-page = 1;
                    }
                }

                NavButton {
                    text: "Mods";
                    active: root.active-page == 2;
                    clicked => {
                        root.active-page = 2;
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                NavButton {
                    text: "Settings";
                    active: root.active-page == 3;
                    clicked => {
                        root.active-page = 3;
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: #30231f;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: #0f1014;

            VerticalLayout {
                padding: 26px;
                spacing: 18px;

                if root.active-page == 0 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        Rectangle {
                            vertical-stretch: 1;
                        }

                        HorizontalLayout {
                            alignment: center;

                            PrimaryButton {
                                text: root.install-action-text;
                                enabled: root.install-action-enabled;
                                clicked => {
                                    root.install-or-play();
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: root.home-support-text;
                                font-size: 13px;
                                color: #a99b91;
                                horizontal-alignment: center;
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: center;

                            SecondaryButton {
                                text: root.update-check-text;
                                enabled: root.update-check-enabled;
                                clicked => {
                                    root.check-updates();
                                }
                            }

                            SecondaryButton {
                                text: "Options";
                                clicked => {
                                    root.active-page = 1;
                                }
                            }

                            SecondaryButton {
                                text: "Repair";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Logs";
                                clicked => {
                                    root.active-page = 3;
                                    root.settings-page = 1;
                                    root.logs-scroll-ticks = 0;
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 1 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        MetricBlock {
                            label: "Known options";
                            value: "This installed version does not expose known launch options yet. Game defaults and DRHL recommended currently add no extra arguments; Custom remains available.";
                        }

                        VerticalLayout {
                            spacing: 12px;

                            LaunchTextField {
                                label: "Pre-launch command";
                                placeholder: "mangohud, gamescope, prime-run...";
                                value <=> root.pre-launch-command;
                            }

                            VerticalLayout {
                                spacing: 8px;

                                HorizontalLayout {
                                    z: 10;
                                    spacing: 8px;
                                    alignment: start;

                                    SmallLabel {
                                        label: "Arguments";
                                    }

                                    InfoHint {
                                        text: "These are original Dungeon Rampage launch options.\nGame defaults uses the game's own defaults.\nDRHL recommended is the launcher default.\nCustom lets you type arguments manually.";
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 0px;

                                    SegmentedButton {
                                        text: "Game defaults";
                                        active: root.launch-arguments-mode == 0;
                                        clicked => {
                                            root.launch-arguments-mode = 0;
                                            root.custom-game-args = "";
                                        }
                                    }

                                    SegmentedButton {
                                        text: "DRHL recommended";
                                        active: root.launch-arguments-mode == 1;
                                        clicked => {
                                            root.launch-arguments-mode = 1;
                                            root.custom-game-args = "";
                                        }
                                    }

                                    SegmentedButton {
                                        text: "Custom";
                                        active: root.launch-arguments-mode == 2;
                                        clicked => {
                                            root.launch-arguments-mode = 2;
                                        }
                                    }
                                }

                                LineEdit {
                                    horizontal-stretch: 1;
                                    enabled: root.launch-arguments-mode == 2;
                                    placeholder-text: "--want-numbered-hud true --quality-control-button false";
                                    text <=> root.custom-game-args;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: end;

                            SecondaryButton {
                                text: "Cancel";
                                enabled: root.launch-options-dirty;
                                clicked => {
                                    root.pre-launch-command = root.saved-pre-launch-command;
                                    root.launch-arguments-mode = root.saved-launch-arguments-mode;
                                    root.custom-game-args = root.saved-custom-game-args;
                                    root.launch-options-save-text = "Save";
                                }
                            }

                            PrimaryButton {
                                text: root.launch-options-dirty ? "Save" : root.launch-options-save-text;
                                enabled: root.launch-options-dirty;
                                clicked => {
                                    root.save-launch-options();
                                }
                            }
                        }

                        reset-save-button := Timer {
                            interval: 2s;
                            running: root.launch-options-save-text != "Save";
                            triggered => {
                                root.launch-options-save-text = "Save";
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 2 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Mods";
                        }

                        MetricBlock {
                            label: "Mod management";
                            value: "No mods installed. This section is ready for packs, activation and compatibility checks.";
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            SecondaryButton {
                                text: "Import";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Open folder";
                                enabled: false;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 3 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Settings";
                        }

                        HorizontalLayout {
                            spacing: 8px;

                            TabButton {
                                text: "General";
                                active: root.settings-page == 0;
                                clicked => {
                                    root.settings-page = 0;
                                }
                            }

                            TabButton {
                                text: "Logs";
                                active: root.settings-page == 1;
                                clicked => {
                                    root.settings-page = 1;
                                    root.logs-scroll-ticks = 0;
                                }
                            }

                            TabButton {
                                text: "About";
                                active: root.settings-page == 2;
                                clicked => {
                                    root.settings-page = 2;
                                }
                            }
                        }

                        if root.settings-page == 0 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            MetricBlock {
                                label: "Install folder";
                                value: "Current launcher configuration.";
                            }

                            MetricBlock {
                                label: "Config file";
                                value: root.config-path;
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                SecondaryButton {
                                    text: "Open install folder";
                                    enabled: root.open-install-folder-enabled;
                                    clicked => {
                                        root.open-install-folder();
                                    }
                                }

                                SecondaryButton {
                                    text: "Open config";
                                    clicked => {
                                        root.open-settings();
                                    }
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }
                        }

                        if root.settings-page == 1 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            Rectangle {
                                vertical-stretch: 1;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: #342724;
                                background: #151419;

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;

                                    SmallLabel {
                                        label: "Recent launcher log";
                                    }

                                    log-scroll := ScrollView {
                                        visible: root.logs-scroll-ticks > 0;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;
                                        viewport-width: self.width;
                                        viewport-height: log-text.height;

                                        log-text := Text {
                                            text: root.logs-content;
                                            width: parent.viewport-width;
                                            font-size: 13px;
                                            color: #ead8ca;
                                            wrap: word-wrap;
                                        }
                                    }

                                    scroll-logs-to-end := Timer {
                                        interval: 1ms;
                                        running: root.active-page == 3 && root.settings-page == 1 && root.logs-scroll-ticks < 3;

                                        triggered => {
                                            log-scroll.viewport-y = -100000px;
                                            root.logs-scroll-ticks += 1;
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                SecondaryButton {
                                    text: "Open logs folder";
                                    enabled: root.open-logs-folder-enabled;
                                    clicked => {
                                        root.open-logs-folder();
                                    }
                                }

                                SecondaryButton {
                                    text: "Refresh";
                                    enabled: root.open-logs-folder-enabled;
                                    clicked => {
                                        root.logs-scroll-ticks = 0;
                                        root.refresh-logs();
                                    }
                                }
                            }
                        }

                        if root.settings-page == 2 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            MetricBlock {
                                label: "DRH Launcher";
                                value: root.launcher-version;
                            }

                            MetricBlock {
                                label: "Release source";
                                value: root.release-source-label;
                            }

                            MetricBlock {
                                label: "License";
                                value: "GPL-3.0-or-later";
                            }

                            SecondaryButton {
                                text: "GitHub";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Discord";
                                enabled: false;
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }
                        }
                    }
                }
            }
        }
    }
}
