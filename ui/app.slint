component LaunchOptionToggle inherits Rectangle {
    in property <string> text;
    in property <bool> checked;
    property <length> label-left-padding: 38px;
    property <length> label-right-padding: 12px;
    out property <float> measured-min-width-px:
        max(112px, measurement.preferred-width + root.label-left-padding + root.label-right-padding) / 1px;
    callback toggled(bool);
    callback width-measured(float);

    init => {
        root.width-measured(root.measured-min-width-px);
    }

    changed measured-min-width-px => {
        root.width-measured(root.measured-min-width-px);
    }

    height: 38px;
    min-width: root.measured-min-width-px * 1px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.checked ? Theme.accent-warm : touch.has-hover ? Theme.border-accent-muted : Theme.border-muted;
    background: root.checked ? Theme.surface-checked : touch.has-hover ? Theme.surface-hover : Theme.panel-background;

    measurement := Text {
        text: root.text;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0px;
        wrap: no-wrap;
        overflow: clip;
        opacity: 0;
    }

    Rectangle {
        x: 12px;
        y: (parent.height - self.height) / 2;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        border-width: 2px;
        border-color: root.checked ? Theme.accent-warm : Theme.border-neutral;
        background: root.checked ? Theme.accent-primary : transparent;

        Text {
            visible: root.checked;
            text: "✓";
            color: Theme.text-on-accent;
            font-size: 13px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: root.label-left-padding;
        width: parent.width - root.label-left-padding - root.label-right-padding;
        text: root.text;
        color: root.checked ? Theme.text-primary : Theme.text-muted;
        font-size: 13px;
        font-weight: root.checked ? 700 : 600;
        letter-spacing: 0px;
        wrap: no-wrap;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        clicked => {
            root.toggled(!root.checked);
        }
    }
}

component InfoHint inherits Rectangle {
    in property <string> text;
    property <bool> hovering: touch.has-hover;
    callback show-tooltip(string, length, length);
    callback hide-tooltip();

    z: 10;
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.border-accent-muted;
    background: touch.has-hover ? Theme.surface-accent : Theme.panel-background;

    Text {
        text: "i";
        color: Theme.text-primary;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    changed hovering => {
        if (root.hovering) {
            root.show-tooltip(root.text, root.absolute-position.x, root.absolute-position.y);
        } else {
            root.hide-tooltip();
        }
    }

    touch := TouchArea {}
}

component AppLineEdit inherits Rectangle {
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> value;

    horizontal-stretch: 1;
    min-height: input.min-height;

    input := LineEdit {
        width: parent.width;
        enabled: root.enabled;
        placeholder-text: root.placeholder;
        text <=> root.value;
    }

    Rectangle {
        visible: input.has-focus;
        width: parent.width;
        height: input.height;
        border-radius: 4px;
        border-width: 2px;
        border-color: Theme.focus;
    }
}

component NumericTextField inherits Rectangle {
    in-out property <string> value;

    width: 48px;
    height: 34px;
    border-radius: 6px;
    border-width: input.has-focus ? 2px : 1px;
    border-color: input.has-focus ? Theme.focus : Theme.border-accent-muted;
    background: Theme.surface-raised;

    input := TextInput {
        x: 6px;
        y: 0px;
        width: parent.width - 12px;
        height: parent.height;
        text <=> root.value;
        single-line: true;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: Theme.text-primary;
        font-size: 14px;
        font-weight: 700;
    }
}

component LaunchTextField inherits Rectangle {
    in property <string> label;
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <string> value;

    horizontal-stretch: 1;
    min-width: 260px;
    min-height: 64px;

    VerticalLayout {
        spacing: 8px;

        SmallLabel {
            label: root.label;
        }

        AppLineEdit {
            enabled: root.enabled;
            placeholder: root.placeholder;
            value <=> root.value;
        }
    }
}

export component AppWindow inherits Window {
    in property <string> install-status;
    in property <string> version-status;
    in property <string> install-action-text;
    in property <bool> install-action-enabled: true;
    in property <string> update-check-text: "Check for updates";
    in property <bool> update-check-enabled: true;
    in property <string> home-support-text;
    in property <string> status-detail;
    in property <[LogLineView]> log-lines;
    in property <[GameSessionView]> game-log-sessions;
    in-out property <int> log-wrap-columns: 120;
    in-out property <int> log-source: 0;
    in-out property <int> selected-game-log-index: -1;
    in property <string> selected-game-log-title: "No game session selected";
    in property <bool> selected-game-log-enabled: false;
    in property <string> launcher-version;
    in property <string> config-path;
    in property <string> install-folder-path;
    in-out property <string> download-cache-limit;
    in-out property <string> saved-download-cache-limit;
    in-out property <string> download-cache-save-text: "Save";
    in-out property <string> download-cache-limit-error;
    property <bool> download-cache-limit-dirty: root.download-cache-limit != root.saved-download-cache-limit;
    property <bool> general-settings-dirty: root.download-cache-limit-dirty;
    in-out property <string> pre-launch-command;
    in-out property <int> launch-arguments-mode: 1;
    in-out property <string> custom-game-args;
    in-out property <string> saved-pre-launch-command;
    in-out property <int> saved-launch-arguments-mode: 1;
    in-out property <string> saved-custom-game-args;
    in-out property <string> launch-options-save-text: "Save";
    in property <[LaunchOptionView]> launch-options;
    in property <float> launch-option-min-width-px: 210;
    in property <float> drhl-metric-min-width-px: 96;
    in property <float> link-button-min-width-px: 120;
    in-out property <string> launch-options-state;
    in-out property <string> saved-launch-options-state;
    property <bool> launch-options-dirty: root.pre-launch-command != root.saved-pre-launch-command
        || root.launch-arguments-mode != root.saved-launch-arguments-mode
        || root.launch-options-state != root.saved-launch-options-state
        || root.custom-game-args != root.saved-custom-game-args;
    in property <bool> open-install-folder-enabled: false;
    in property <bool> open-logs-folder-enabled: false;
    in property <bool> restore-previous-visible: false;
    in property <bool> restore-previous-enabled: false;
    in property <string> restore-previous-text: "Restore previous";
    in property <bool> reinstall-current-enabled: false;
    in property <string> reinstall-current-text: "Reinstall current";
    in-out property <int> active-page: 0;
    in-out property <int> settings-page: 0;
    in-out property <bool> advanced-settings-open: false;
    in-out property <bool> help-menu-open: false;
    property <bool> info-tooltip-visible: false;
    property <string> info-tooltip-text;
    property <length> info-tooltip-anchor-x: 0px;
    property <length> info-tooltip-anchor-y: 0px;

    callback install-or-play();
    callback check-updates();
    callback open-config-folder();
    callback open-install-folder();
    callback open-logs-folder();
    callback open-selected-game-log();
    callback open-discord-link();
    callback open-drh-github-link();
    callback open-drhl-github-link();
    callback open-ax4-github-link();
    callback refresh-logs();
    callback select-log-source(int);
    callback select-game-log(int);
    callback log-wrap-columns-measured(int);
    callback increment-download-cache-limit();
    callback decrement-download-cache-limit();
    callback save-general-settings();
    callback cancel-general-settings();
    callback restore-previous-version();
    callback reinstall-current-version();
    callback save-launch-options();
    callback select-launch-arguments-mode(int);
    callback toggle-launch-option(int, bool);
    callback launch-option-width-measured(float);
    callback drhl-metric-width-measured(float);
    callback link-button-width-measured(float);
    callback cancel-launch-options();

    changed download-cache-limit => {
        root.download-cache-limit-error = "";
    }

    title: "DRH Launcher";
    icon: @image-url("../assets/icons/app-icon-1024.png");
    preferred-width: 1280px;
    preferred-height: 720px;
    min-width: 720px;
    min-height: 480px;
    background: Theme.app-background;

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: 188px;
            background: Theme.sidebar-background;

            VerticalLayout {
                padding: 18px;
                spacing: 10px;

                VerticalLayout {
                    spacing: 2px;

                    Text {
                        text: "DRH Launcher";
                        color: Theme.text-title;
                        font-size: 15px;
                        font-weight: 800;
                    }

                    Text {
                        text: "Dungeon Rampage Haxe";
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 700;
                        wrap: word-wrap;
                    }
                }

                Rectangle {
                    height: 12px;
                }

                NavButton {
                    text: "Home";
                    active: root.active-page == 0;
                    clicked => {
                        root.active-page = 0;
                    }
                }

                NavButton {
                    text: "Options";
                    active: root.active-page == 1;
                    clicked => {
                        root.active-page = 1;
                    }
                }

                NavButton {
                    text: "Mods";
                    active: root.active-page == 2;
                    clicked => {
                        root.active-page = 2;
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                NavButton {
                    text: "Settings";
                    active: root.active-page == 3;
                    clicked => {
                        root.active-page = 3;
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: Theme.divider;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: Theme.app-background;

            VerticalLayout {
                padding: 26px;
                spacing: 18px;

                if root.active-page == 0 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        Rectangle {
                            vertical-stretch: 1;
                        }

                        HorizontalLayout {
                            alignment: center;

                            PrimaryButton {
                                text: root.install-action-text;
                                enabled: root.install-action-enabled;
                                clicked => {
                                    root.install-or-play();
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: root.home-support-text;
                                font-size: 13px;
                                color: Theme.text-support;
                                horizontal-alignment: center;
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: center;

                            SecondaryButton {
                                text: root.update-check-text;
                                enabled: root.update-check-enabled;
                                clicked => {
                                    root.help-menu-open = false;
                                    root.check-updates();
                                }
                            }

                            SecondaryButton {
                                text: "Options";
                                clicked => {
                                    root.help-menu-open = false;
                                    root.active-page = 1;
                                }
                            }

                            HelpMenuButton {
                                active: root.help-menu-open;
                                clicked => {
                                    root.help-menu-open = !root.help-menu-open;
                                }
                            }

                        }

                        if root.help-menu-open : HorizontalLayout {
                            horizontal-stretch: 1;
                            min-height: 74px;
                            alignment: center;

                            Rectangle {
                                width: 520px;
                                min-height: 58px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.border-accent-muted;
                                background: Theme.surface;
                                drop-shadow-blur: 10px;
                                drop-shadow-offset-y: 3px;
                                drop-shadow-color: Theme.shadow-strong;

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    padding-top: 10px;
                                    padding-bottom: 10px;
                                    alignment: center;
                                    spacing: 10px;

                                    if root.restore-previous-visible : SecondaryButton {
                                        text: root.restore-previous-text;
                                        enabled: root.restore-previous-enabled;
                                        clicked => {
                                            root.help-menu-open = false;
                                            root.restore-previous-version();
                                        }
                                    }

                                    SecondaryButton {
                                        text: root.reinstall-current-text;
                                        enabled: root.reinstall-current-enabled;
                                        clicked => {
                                            root.help-menu-open = false;
                                            root.reinstall-current-version();
                                        }
                                    }

                                    SecondaryButton {
                                        text: "Open logs";
                                        clicked => {
                                            root.help-menu-open = false;
                                            root.active-page = 3;
                                            root.settings-page = 1;
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 1 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        options-page-scroll := ScrollView {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            viewport-width: self.width;
                            viewport-height: options-page-content.preferred-height;

                            options-page-content := VerticalLayout {
                                width: options-page-scroll.width;
                                spacing: 12px;

                                LaunchTextField {
                                    label: "Pre-launch command";
                                    placeholder: "mangohud, gamescope, prime-run...";
                                    value <=> root.pre-launch-command;
                                }

                                VerticalLayout {
                                    spacing: 8px;

                                    HorizontalLayout {
                                        z: 10;
                                        spacing: 8px;
                                        alignment: start;

                                        SmallLabel {
                                            label: "Arguments";
                                        }

                                        InfoHint {
                                            text: "These are original Dungeon Rampage launch options.\nGame defaults uses the game's own defaults.\nDRHL recommended is the launcher default.\nCustom lets you adjust known options manually.";
                                            show-tooltip(text, x, y) => {
                                                root.info-tooltip-text = text;
                                                root.info-tooltip-anchor-x = x;
                                                root.info-tooltip-anchor-y = y;
                                                root.info-tooltip-visible = true;
                                            }
                                            hide-tooltip => {
                                                root.info-tooltip-visible = false;
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 0px;

                                        SegmentedButton {
                                            text: "Game defaults";
                                            active: root.launch-arguments-mode == 0;
                                            clicked => {
                                                root.select-launch-arguments-mode(0);
                                            }
                                        }

                                        SegmentedButton {
                                            text: "DRHL recommended";
                                            active: root.launch-arguments-mode == 1;
                                            clicked => {
                                                root.select-launch-arguments-mode(1);
                                            }
                                        }

                                        SegmentedButton {
                                            text: "Custom";
                                            active: root.launch-arguments-mode == 2;
                                            clicked => {
                                                root.select-launch-arguments-mode(2);
                                            }
                                        }
                                    }

                                    if root.launch-options.length > 0 : option-area := Rectangle {
                                        horizontal-stretch: 1;
                                        height: option-grid.preferred-height;

                                        option-grid := GridLayout {
                                            width: parent.width;
                                            property <length> available-width: option-area.width;
                                            property <int> columns:
                                                option-grid.available-width >= root.launch-option-min-width-px * 4px + 24px ? 4
                                                : option-grid.available-width >= root.launch-option-min-width-px * 3px + 16px ? 3
                                                : option-grid.available-width >= root.launch-option-min-width-px * 2px + 8px ? 2
                                                : 1;
                                            spacing: 8px;

                                            for option[index] in root.launch-options: LaunchOptionToggle {
                                                min-width: root.launch-option-min-width-px * 1px;
                                                row: index / option-grid.columns;
                                                col: Math.mod(index, option-grid.columns);
                                                text: option.name;
                                                checked: option.checked;
                                                toggled(checked) => {
                                                    root.toggle-launch-option(index, checked);
                                                }
                                                width-measured(width) => {
                                                    root.launch-option-width-measured(width);
                                                }
                                            }
                                        }
                                    }

                                    if root.launch-options.length == 0 : Text {
                                        text: "No known launch options loaded from the release manifest.";
                                        color: Theme.text-support;
                                        font-size: 13px;
                                    }

                                    SmallLabel {
                                        label: "Extra arguments";
                                    }

                                    AppLineEdit {
                                        placeholder: "Extra arguments";
                                        value <=> root.custom-game-args;
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: end;

                            SecondaryButton {
                                text: "Cancel";
                                enabled: root.launch-options-dirty;
                                clicked => {
                                    root.cancel-launch-options();
                                }
                            }

                            PrimaryButton {
                                text: root.launch-options-dirty ? "Save" : root.launch-options-save-text;
                                enabled: root.launch-options-dirty;
                                clicked => {
                                    root.save-launch-options();
                                }
                            }
                        }

                        reset-save-button := Timer {
                            interval: 2s;
                            running: root.launch-options-save-text != "Save";
                            triggered => {
                                root.launch-options-save-text = "Save";
                            }
                        }
                    }
                }

                if root.active-page == 2 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Mods";
                        }

                        MetricBlock {
                            label: "Mod management";
                            value: "Modding isn't supported yet.";
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            SecondaryButton {
                                text: "Import";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Open folder";
                                enabled: false;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 3 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Settings";
                        }

                        HorizontalLayout {
                            spacing: 8px;

                            TabButton {
                                text: "General";
                                active: root.settings-page == 0;
                                clicked => {
                                    root.settings-page = 0;
                                }
                            }

                            TabButton {
                                text: "Logs";
                                active: root.settings-page == 1;
                                clicked => {
                                    root.settings-page = 1;
                                }
                            }

                            TabButton {
                                text: "About";
                                active: root.settings-page == 2;
                                clicked => {
                                    root.settings-page = 2;
                                }
                            }
                        }

                        if root.settings-page == 0 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            general-page-scroll := ScrollView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;
                                viewport-width: self.width;
                                viewport-height: general-page-content.preferred-height;

                                general-page-content := VerticalLayout {
                                    width: general-page-scroll.width;
                                    spacing: 12px;

                                    SettingsCard {
                                        title: "Installation";
                                        description: "Contains launcher data, downloaded archives, logs, and Dungeon Rampage Haxe.";

                                        Text {
                                            text: root.install-folder-path;
                                            font-size: 13px;
                                            color: Theme.text-body;
                                            wrap: word-wrap;
                                        }

                                        HorizontalLayout {
                                            spacing: 10px;
                                            alignment: start;

                                            SecondaryButton {
                                                text: "Open folder";
                                                enabled: root.open-install-folder-enabled;
                                                clicked => {
                                                    root.open-install-folder();
                                                }
                                            }
                                        }
                                    }

                                    SettingsCard {
                                        title: "Download cache";
                                        description: "Keeps this many verified release archives in data/downloads. Cached archives can speed up reinstalls, repairs, and rollbacks, but use disk space. Set 0 to avoid keeping completed archives.";

                                        HorizontalLayout {
                                            spacing: 8px;
                                            alignment: start;

                                            StepperButton {
                                                text: "-";
                                                clicked => {
                                                    root.decrement-download-cache-limit();
                                                }
                                            }

                                            NumericTextField {
                                                value <=> root.download-cache-limit;
                                            }

                                            StepperButton {
                                                text: "+";
                                                clicked => {
                                                    root.increment-download-cache-limit();
                                                }
                                            }
                                        }

                                        if root.download-cache-limit-error != "" : Text {
                                            text: root.download-cache-limit-error;
                                            font-size: 13px;
                                            color: Theme.accent-primary-hover;
                                            wrap: word-wrap;
                                        }
                                    }

                                    VerticalLayout {
                                        spacing: 8px;

                                        SecondaryButton {
                                            text: root.advanced-settings-open ? "Hide advanced settings" : "Advanced settings";
                                            clicked => {
                                                root.advanced-settings-open = !root.advanced-settings-open;
                                            }
                                        }

                                        if root.advanced-settings-open : SettingsCard {
                                            title: "Config file";
                                            description: "Manual edits are usually not needed. Use this only for diagnostics or unsupported changes.";

                                            Text {
                                                text: root.config-path;
                                                font-size: 13px;
                                                color: Theme.text-body;
                                                wrap: word-wrap;
                                            }

                                            HorizontalLayout {
                                                spacing: 10px;
                                                alignment: start;

                                                SecondaryButton {
                                                    text: "Open config folder";
                                                    clicked => {
                                                        root.open-config-folder();
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                alignment: end;

                                SecondaryButton {
                                    text: "Cancel";
                                    enabled: root.general-settings-dirty;
                                    clicked => {
                                        root.cancel-general-settings();
                                    }
                                }

                                PrimaryButton {
                                    text: root.general-settings-dirty ? "Save" : root.download-cache-save-text;
                                    enabled: root.general-settings-dirty;
                                    clicked => {
                                        root.save-general-settings();
                                    }
                                }
                            }
                        }

                        if root.settings-page == 1 : VerticalLayout {
                            spacing: 12px;
                            vertical-stretch: 1;

                            HorizontalLayout {
                                spacing: 8px;

                                TabButton {
                                    text: "Launcher";
                                    active: root.log-source == 0;
                                    clicked => {
                                        root.select-log-source(0);
                                    }
                                }

                                TabButton {
                                    text: "Game sessions";
                                    active: root.log-source == 1;
                                    clicked => {
                                        root.select-log-source(1);
                                    }
                                }
                            }

                            if root.log-source == 0 : LogViewer {
                                title: "Recent launcher log";
                                lines: root.log-lines;
                                scroll-to-end: true;
                                horizontal-stretch: 1;
                                vertical-stretch: 1;
                                wrap-columns-measured(columns) => {
                                    root.log-wrap-columns-measured(columns);
                                }
                            }

                            if root.log-source == 1 : HorizontalLayout {
                                spacing: 12px;
                                vertical-stretch: 1;

                                Rectangle {
                                    width: 200px;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: Theme.border-muted;
                                    background: Theme.panel-background;

                                    VerticalLayout {
                                        padding: 10px;
                                        spacing: 8px;

                                        SmallLabel {
                                            label: "Game sessions";
                                        }

                                        session-list := ListView {
                                            horizontal-stretch: 1;
                                            vertical-stretch: 1;

                                            for session[index] in root.game-log-sessions: GameSessionButton {
                                                title: session.title;
                                                detail: session.detail;
                                                active: root.selected-game-log-index == index;
                                                clicked => {
                                                    root.select-game-log(index);
                                                }
                                            }
                                        }
                                    }
                                }

                                LogViewer {
                                    title: root.selected-game-log-title;
                                    lines: root.log-lines;
                                    scroll-to-end: false;
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    wrap-columns-measured(columns) => {
                                        root.log-wrap-columns-measured(columns);
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                SecondaryButton {
                                    text: "Open logs folder";
                                    enabled: root.open-logs-folder-enabled;
                                    clicked => {
                                        root.open-logs-folder();
                                    }
                                }

                                if root.log-source == 1 : SecondaryButton {
                                    text: "Open selected file";
                                    enabled: root.selected-game-log-enabled;
                                    clicked => {
                                        root.open-selected-game-log();
                                    }
                                }

                                SecondaryButton {
                                    text: "Refresh";
                                    enabled: root.open-logs-folder-enabled;
                                    clicked => {
                                        root.refresh-logs();
                                    }
                                }
                            }
                        }

                        if root.settings-page == 2 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            about-page-scroll := ScrollView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;
                                viewport-width: self.width;
                                viewport-height: about-page-content.preferred-height;

                                about-page-content := VerticalLayout {
                                    width: about-page-scroll.width;
                                    spacing: 12px;

                                    SettingsCard {
                                        title: "Dungeon Rampage Haxe";
                                        description: "A Haxe & OpenFL port of Dungeon Rampage, intended as a higher-performance, responsive version of the original game, for a smoother experience.";

                                        SmallLabel {
                                            label: "Technologies";
                                        }

                                        Text {
                                            text: "Haxe, ax4, and forks of OpenFL, Lime, HXCPP, SWF and SteamWrap. ax4 is my ActionScript 3 to Haxe converter; it also provides DRH's runtime compatibility layer.";
                                            font-size: 13px;
                                            color: Theme.text-body;
                                            wrap: word-wrap;
                                        }
                                    }

                                    SettingsCard {
                                        title: "DRH Launcher";
                                        description: "The recommended way to install, update, configure, and play Dungeon Rampage Haxe.";

                                        drhl-metrics-area := Rectangle {
                                            horizontal-stretch: 1;
                                            height: drhl-metrics-grid.preferred-height;

                                            drhl-metrics-grid := GridLayout {
                                                width: parent.width;
                                                property <length> available-width: drhl-metrics-area.width;
                                                property <int> columns:
                                                    drhl-metrics-grid.available-width >= root.drhl-metric-min-width-px * 3px + 12px ? 3
                                                    : drhl-metrics-grid.available-width >= root.drhl-metric-min-width-px * 2px + 6px ? 2
                                                    : 1;
                                                spacing: 6px;

                                                CompactMetricBlock {
                                                    min-width: root.drhl-metric-min-width-px * 1px;
                                                    row: 0;
                                                    col: 0;
                                                    label: "Version";
                                                    value: root.launcher-version;
                                                    width-measured(width) => {
                                                        root.drhl-metric-width-measured(width);
                                                    }
                                                }

                                                CompactMetricBlock {
                                                    min-width: root.drhl-metric-min-width-px * 1px;
                                                    row: 0 / drhl-metrics-grid.columns;
                                                    col: Math.mod(1, drhl-metrics-grid.columns);
                                                    label: "Technologies";
                                                    value: "Rust and Slint";
                                                    width-measured(width) => {
                                                        root.drhl-metric-width-measured(width);
                                                    }
                                                }

                                                CompactMetricBlock {
                                                    min-width: root.drhl-metric-min-width-px * 1px;
                                                    row: 2 / drhl-metrics-grid.columns;
                                                    col: Math.mod(2, drhl-metrics-grid.columns);
                                                    label: "License";
                                                    value: "GPL-3.0-or-later";
                                                    width-measured(width) => {
                                                        root.drhl-metric-width-measured(width);
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    SettingsCard {
                                        title: "Project and rights";
                                        description: "DRH, DRH Launcher and ax4 are maintained by Tutez and developed with public source repositories.";

                                        Text {
                                            text: "DRH Launcher and ax4 are free software under GPL-3.0-or-later and MIT respectively. DRH source code is publicly available, but parts of DRH derive from the original game and include original assets or third-party libraries, so their original rights and licenses still apply.";
                                            font-size: 13px;
                                            color: Theme.text-body;
                                            wrap: word-wrap;
                                        }
                                    }

                                    SettingsCard {
                                        title: "Links";
                                        description: "Community and source repositories. If you appreciate my work, starring the GitHub repositories helps support the projects.";

                                        link-buttons-area := Rectangle {
                                            horizontal-stretch: 1;
                                            height: link-buttons-grid.preferred-height;

                                            link-buttons-grid := GridLayout {
                                                width: parent.width;
                                                property <length> available-width: link-buttons-area.width;
                                                property <int> columns:
                                                    link-buttons-grid.available-width >= root.link-button-min-width-px * 4px + 30px ? 4
                                                    : link-buttons-grid.available-width >= root.link-button-min-width-px * 3px + 20px ? 3
                                                    : link-buttons-grid.available-width >= root.link-button-min-width-px * 2px + 10px ? 2
                                                    : 1;
                                                spacing: 10px;

                                                LinkButton {
                                                    min-width: root.link-button-min-width-px * 1px;
                                                    row: 0;
                                                    col: 0;
                                                    text: "Discord";
                                                    icon-kind: 0;
                                                    clicked => {
                                                        root.open-discord-link();
                                                    }
                                                    width-measured(width) => {
                                                        root.link-button-width-measured(width);
                                                    }
                                                }

                                                LinkButton {
                                                    min-width: root.link-button-min-width-px * 1px;
                                                    row: 1 / link-buttons-grid.columns;
                                                    col: Math.mod(1, link-buttons-grid.columns);
                                                    text: "DRH GitHub";
                                                    icon-kind: 1;
                                                    clicked => {
                                                        root.open-drh-github-link();
                                                    }
                                                    width-measured(width) => {
                                                        root.link-button-width-measured(width);
                                                    }
                                                }

                                                LinkButton {
                                                    min-width: root.link-button-min-width-px * 1px;
                                                    row: 2 / link-buttons-grid.columns;
                                                    col: Math.mod(2, link-buttons-grid.columns);
                                                    text: "DRHL GitHub";
                                                    icon-kind: 1;
                                                    clicked => {
                                                        root.open-drhl-github-link();
                                                    }
                                                    width-measured(width) => {
                                                        root.link-button-width-measured(width);
                                                    }
                                                }

                                                LinkButton {
                                                    min-width: root.link-button-min-width-px * 1px;
                                                    row: 3 / link-buttons-grid.columns;
                                                    col: Math.mod(3, link-buttons-grid.columns);
                                                    text: "ax4 GitHub";
                                                    icon-kind: 1;
                                                    clicked => {
                                                        root.open-ax4-github-link();
                                                    }
                                                    width-measured(width) => {
                                                        root.link-button-width-measured(width);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    reset-cache-save-button := Timer {
        interval: 2s;
        running: root.download-cache-save-text != "Save" && !root.download-cache-limit-dirty;
        triggered => {
            root.download-cache-save-text = "Save";
        }
    }

    Rectangle {
        z: 1000;
        visible: root.info-tooltip-visible;
        width: min(390px, root.width - 16px);
        height: info-tooltip-text.preferred-height + 16px;
        x: min(max(root.info-tooltip-anchor-x - 74px, 8px), root.width - self.width - 8px);
        y: max(root.info-tooltip-anchor-y - self.height - 14px, 8px);
        border-radius: 6px;
        border-width: 1px;
        border-color: Theme.border-accent-muted;
        background: Theme.surface-raised;

        info-tooltip-text := Text {
            x: 10px;
            y: 8px;
            width: parent.width - 20px;
            text: root.info-tooltip-text;
            color: Theme.text-body;
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}
