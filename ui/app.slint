import { CheckBox, LineEdit, ScrollView } from "std-widgets.slint";

component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 168px;
    min-height: 42px;
    border-radius: 6px;
    background: !root.enabled ? #5b2723 : touch.pressed ? #9f241c : touch.has-hover ? #e1502f : #c73325;

    Text {
        text: root.text;
        color: root.enabled ? #fff7ed : #a9948d;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component SecondaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    min-width: 142px;
    min-height: 38px;
    border-radius: 6px;
    border-width: 1px;
    border-color: !root.enabled ? #3f302d : touch.has-hover ? #f07a37 : #6d3327;
    background: !root.enabled ? #18171a : touch.pressed ? #3a1c18 : touch.has-hover ? #2b1816 : #20171a;

    Text {
        text: root.text;
        color: root.enabled ? #f3d8c4 : #776b66;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component NavButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    height: 42px;
    border-radius: 6px;
    background: root.active ? #3a1f1b : touch.has-hover ? #211b1e : transparent;
    border-width: root.active ? 1px : 0px;
    border-color: #743325;

    Text {
        text: root.text;
        color: root.active ? #fff1dd : #cbb8ab;
        font-size: 14px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: left;
        vertical-alignment: center;
        x: 14px;
        width: parent.width - 28px;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    min-width: 108px;
    height: 36px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? #743325 : #342724;
    background: root.active ? #3a1f1b : touch.has-hover ? #211b1e : #151419;

    Text {
        text: root.text;
        color: root.active ? #fff1dd : #cbb8ab;
        font-size: 13px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component MetricBlock inherits Rectangle {
    in property <string> label;
    in property <string> value;

    min-height: 78px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #3c2a26;
    background: #17151a;

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        Text {
            text: root.label;
            font-size: 12px;
            font-weight: 700;
            color: #f07a37;
        }

        Text {
            text: root.value;
            font-size: 15px;
            color: #ead8ca;
            wrap: word-wrap;
        }
    }
}

component SectionTitle inherits Text {
    in property <string> title;

    text: root.title;
    font-size: 18px;
    font-weight: 700;
    color: #fff0dc;
}

component SmallLabel inherits Text {
    in property <string> label;

    text: root.label;
    font-size: 12px;
    font-weight: 700;
    color: #c48a66;
}

component OptionRow inherits Rectangle {
    in property <string> title;
    in property <string> description;

    min-height: 58px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #342724;
    background: #151419;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;
        alignment: center;

        VerticalLayout {
            spacing: 3px;

            Text {
                text: root.title;
                font-size: 14px;
                font-weight: 700;
                color: #f3dfcf;
            }

            Text {
                text: root.description;
                font-size: 12px;
                color: #a99b91;
                wrap: word-wrap;
            }
        }

        CheckBox {
            enabled: false;
        }
    }
}

export component AppWindow inherits Window {
    in property <string> install-status;
    in property <string> version-status;
    in property <string> install-action-text;
    in property <bool> install-action-enabled: true;
    in property <string> update-check-text: "Check for updates";
    in property <bool> update-check-enabled: true;
    in property <string> home-support-text;
    in property <string> status-detail;
    in property <string> logs-content;
    in property <string> launcher-version;
    in property <string> release-source-label;
    in property <string> config-path;
    in property <bool> open-install-folder-enabled: false;
    in property <bool> open-logs-folder-enabled: false;
    in-out property <int> active-page: 0;
    in-out property <int> settings-page: 0;
    property <int> logs-scroll-ticks: 0;

    callback install-or-play();
    callback check-updates();
    callback open-settings();
    callback open-install-folder();
    callback open-logs-folder();
    callback refresh-logs();

    title: "DRH Launcher";
    preferred-width: 980px;
    preferred-height: 620px;
    min-width: 820px;
    min-height: 520px;
    background: #0f1014;

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: 188px;
            background: #121116;

            VerticalLayout {
                padding: 18px;
                spacing: 10px;

                Text {
                    text: "Dungeon Rampage Haxe";
                    color: #ffe6c5;
                    font-size: 14px;
                    font-weight: 800;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 12px;
                }

                NavButton {
                    text: "Home";
                    active: root.active-page == 0;
                    clicked => {
                        root.active-page = 0;
                    }
                }

                NavButton {
                    text: "Options";
                    active: root.active-page == 1;
                    clicked => {
                        root.active-page = 1;
                    }
                }

                NavButton {
                    text: "Mods";
                    active: root.active-page == 2;
                    clicked => {
                        root.active-page = 2;
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                NavButton {
                    text: "Settings";
                    active: root.active-page == 3;
                    clicked => {
                        root.active-page = 3;
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: #30231f;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: #0f1014;

            VerticalLayout {
                padding: 26px;
                spacing: 18px;

                if root.active-page == 0 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        Rectangle {
                            vertical-stretch: 1;
                        }

                        HorizontalLayout {
                            alignment: center;

                            PrimaryButton {
                                text: root.install-action-text;
                                enabled: root.install-action-enabled;
                                clicked => {
                                    root.install-or-play();
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: root.home-support-text;
                                font-size: 13px;
                                color: #a99b91;
                                horizontal-alignment: center;
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: center;

                            SecondaryButton {
                                text: root.update-check-text;
                                enabled: root.update-check-enabled;
                                clicked => {
                                    root.check-updates();
                                }
                            }

                            SecondaryButton {
                                text: "Options";
                                clicked => {
                                    root.active-page = 1;
                                }
                            }

                            SecondaryButton {
                                text: "Repair";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Logs";
                                clicked => {
                                    root.active-page = 3;
                                    root.settings-page = 1;
                                    root.logs-scroll-ticks = 0;
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 1 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Launch Options";
                        }

                        HorizontalLayout {
                            spacing: 12px;

                            VerticalLayout {
                                spacing: 8px;
                                horizontal-stretch: 1;

                                SmallLabel {
                                    label: "Pre-launch command";
                                }

                                LineEdit {
                                    placeholder-text: "mangohud, gamescope, prime-run...";
                                    enabled: false;
                                }
                            }

                            VerticalLayout {
                                spacing: 8px;
                                horizontal-stretch: 1;

                                SmallLabel {
                                    label: "Arguments DRH";
                                }

                                LineEdit {
                                    placeholder-text: "--flag=value";
                                    enabled: false;
                                }
                            }
                        }

                        OptionRow {
                            title: "Use recommended arguments";
                            description: "Will be populated from DRH release metadata.";
                        }

                        OptionRow {
                            title: "Add to Steam";
                            description: "Create a Steam shortcut to DRH Launcher with --play mode.";
                        }

                        OptionRow {
                            title: "Advanced mode";
                            description: "Allow custom arguments not listed by the release.";
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 2 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Mods";
                        }

                        MetricBlock {
                            label: "Mod management";
                            value: "No mods installed. This section is ready for packs, activation and compatibility checks.";
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            SecondaryButton {
                                text: "Import";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Open folder";
                                enabled: false;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }

                if root.active-page == 3 : Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 16px;

                        SectionTitle {
                            title: "Settings";
                        }

                        HorizontalLayout {
                            spacing: 8px;

                            TabButton {
                                text: "General";
                                active: root.settings-page == 0;
                                clicked => {
                                    root.settings-page = 0;
                                }
                            }

                            TabButton {
                                text: "Logs";
                                active: root.settings-page == 1;
                                clicked => {
                                    root.settings-page = 1;
                                    root.logs-scroll-ticks = 0;
                                }
                            }

                            TabButton {
                                text: "About";
                                active: root.settings-page == 2;
                                clicked => {
                                    root.settings-page = 2;
                                }
                            }
                        }

                        if root.settings-page == 0 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            MetricBlock {
                                label: "Install folder";
                                value: "Current launcher configuration.";
                            }

                            MetricBlock {
                                label: "Config file";
                                value: root.config-path;
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                SecondaryButton {
                                    text: "Open install folder";
                                    enabled: root.open-install-folder-enabled;
                                    clicked => {
                                        root.open-install-folder();
                                    }
                                }

                                SecondaryButton {
                                    text: "Open config";
                                    clicked => {
                                        root.open-settings();
                                    }
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }
                        }

                        if root.settings-page == 1 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            Rectangle {
                                vertical-stretch: 1;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: #342724;
                                background: #151419;

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;

                                    SmallLabel {
                                        label: "Recent launcher log";
                                    }

                                    log-scroll := ScrollView {
                                        visible: root.logs-scroll-ticks > 0;
                                        horizontal-stretch: 1;
                                        vertical-stretch: 1;
                                        viewport-width: self.width;
                                        viewport-height: log-text.height;

                                        log-text := Text {
                                            text: root.logs-content;
                                            width: parent.viewport-width;
                                            font-size: 13px;
                                            color: #ead8ca;
                                            wrap: word-wrap;
                                        }
                                    }

                                    scroll-logs-to-end := Timer {
                                        interval: 1ms;
                                        running: root.active-page == 3 && root.settings-page == 1 && root.logs-scroll-ticks < 3;

                                        triggered => {
                                            log-scroll.viewport-y = -100000px;
                                            root.logs-scroll-ticks += 1;
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                SecondaryButton {
                                    text: "Open logs folder";
                                    enabled: root.open-logs-folder-enabled;
                                    clicked => {
                                        root.open-logs-folder();
                                    }
                                }

                                SecondaryButton {
                                    text: "Refresh";
                                    enabled: root.open-logs-folder-enabled;
                                    clicked => {
                                        root.logs-scroll-ticks = 0;
                                        root.refresh-logs();
                                    }
                                }
                            }
                        }

                        if root.settings-page == 2 : VerticalLayout {
                            spacing: 16px;
                            vertical-stretch: 1;

                            MetricBlock {
                                label: "DRH Launcher";
                                value: root.launcher-version;
                            }

                            MetricBlock {
                                label: "Release source";
                                value: root.release-source-label;
                            }

                            MetricBlock {
                                label: "License";
                                value: "GPL-3.0-or-later";
                            }

                            SecondaryButton {
                                text: "GitHub";
                                enabled: false;
                            }

                            SecondaryButton {
                                text: "Discord";
                                enabled: false;
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }
                        }
                    }
                }
            }
        }
    }
}
