    border-radius: 6px;
    border-width: 1px;
    border-color: !root.enabled ? Theme.border-disabled : touch.has-hover ? Theme.accent-warm : Theme.border-accent-muted;
    background: !root.enabled ? Theme.surface : touch.pressed ? Theme.surface-pressed : touch.has-hover ? Theme.surface-accent : Theme.surface-raised;

    Text {
        text: root.text;
        color: root.enabled ? Theme.text-primary : Theme.text-disabled;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

